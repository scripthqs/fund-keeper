# ==================== LLM 配置 ====================
# 你的 DeepSeek / OpenAI API Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API 基础地址（DeepSeek 或其他兼容接口）
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
LLM_MODEL=deepseek-chat

# 快速模型（可选）：用于策略推荐/宏观分析/情绪文案等规则明确的场景，速度快 2-3 倍
# 建议 LLM_MODEL 用推理模型（如 deepseek-v4-pro）时，这里配一个非推理模型（如 deepseek-chat）
# 留空则所有场景都使用 LLM_MODEL
LLM_FAST_MODEL=

# ==================== 认证配置 ====================
# 通用密码：可使用此密码登录任意账号（请设置为强密码）
UNIVERSAL_PASSWORD=your_universal_password_here

# ==================== 服务配置 ====================
# 热重载（仅本地开发设为 true；生产环境保持 false 或不设置）
RELOAD=false

# 监听地址（0.0.0.0 表示所有网卡）
HOST=0.0.0.0

# 监听端口
PORT=8000

# CORS 允许的来源（生产环境建议改为你的域名，如 https://yourdomain.com）
CORS_ORIGINS=*
